pkgname=tsync
pkgver=0.1.5
pkgrel=1
pkgdesc="CLI utility to sync your local music library to another device"
arch=('x86_64')
url="https://github.com/curstantine/tsync"
license=('MIT')
depends=()
optdepends=(
    'ffmpeg: for on-the-fly transcoding (optional)'
    'opus-tools: for encoding to Opus via opus-tools (optional)'
    'adb: to sync via Android Debug Bridge (optional)'
)
source=("$pkgname-$pkgver.tar.gz::https://github.com/Curstantine/tsync/releases/download/v$pkgver/tsync-unix.tar.gz")
sha256sums=('1fdd52ae5eb2ffa6dd905c65f1c3594168c395c9012c389516b0aa4e419c36f2')

prepare() {
    tar -xzf "$srcdir/$pkgname-$pkgver.tar.gz" -C "$srcdir"
}

package() {
    cd "$srcdir"
    install -Dm755 ./tsync "$pkgdir/usr/bin/tsync"

    # install completion scripts
    install -Dm644 completions/tsync.bash "$pkgdir/usr/share/bash-completion/completions/tsync"
    install -Dm644 completions/_tsync "$pkgdir/usr/share/zsh/site-functions/_tsync"
    install -Dm644 completions/tsync.fish "$pkgdir/usr/share/fish/vendor_completions.d/tsync.fish"
}
